[Unit]
Description=Craft-Device API Server
After=network.target

[Service]
Type=simple
User=craft
Group=craft
WorkingDirectory=/opt/craft-device/backend
Environment=PATH=/opt/craft-device/backend/venv/bin:/usr/bin
ExecStart=/opt/craft-device/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
